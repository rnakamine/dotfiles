theme = One Half Dark
# theme = Tomorrow Night
macos-titlebar-style = tabs
font-family = "JetBrains Mono"
# title = " "
copy-on-select = clipboard

cursor-style = block
shell-integration-features = no-cursor

split-divider-color = gray
unfocused-split-opacity = 0.7

keybind = ctrl+t>h=goto_split:left
keybind = ctrl+t>j=goto_split:bottom
keybind = ctrl+t>k=goto_split:top
keybind = ctrl+t>l=goto_split:right

keybind = ctrl+t>shift+backslash=new_split:right
keybind = ctrl+t>minus=new_split:down

keybind = ctrl+t>c=new_tab

keybind = ctrl+t>n=next_tab
keybind = ctrl+t>p=previous_tab

keybind = ctrl+t>shift+h=resize_split:left,200
keybind = ctrl+t>shift+j=resize_split:down,200
keybind = ctrl+t>shift+k=resize_split:up,200
keybind = ctrl+t>shift+l=resize_split:right,200

keybind = ctrl+t>y=toggle_split_zoom

keybind = ctrl+t>ctrl+t=text:\x14
